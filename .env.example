# ChatterBox 환경 변수 템플릿 — git 추적 대상.
# 실제 값은 .env.development / .env.staging / .env.production (gitignored)에 채운다.
# SSOT: docs/PLATFORM-ARCHITECTURE.md §2.4

# ── 클라이언트 (VITE_ 접두사, 번들에 노출됨) ──────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_LIVEKIT_URL=
VITE_SENTRY_DSN=
VITE_ENV=development
# 간편인증(OAuth) 버튼 노출 게이트. "kakao,google" 설정 시 소셜 로그인 노출 + 이메일 강등(토글 뒤로).
# 비우면 이메일 로그인만 노출. Supabase 대시보드 프로바이더 등록 + 카카오 비즈앱 검수 선행 필수.
VITE_OAUTH_PROVIDERS=

# ── Edge Function 전용 (비공개, 클라이언트 번들에 절대 노출 금지) ──
SUPABASE_SERVICE_ROLE_KEY=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SERVER_URL=
FAL_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
