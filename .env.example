# ChatterBox 환경 변수 템플릿 — git 추적 대상.
# 실제 값은 .env.development / .env.staging / .env.production (gitignored)에 채운다.
# SSOT: docs/PLATFORM-ARCHITECTURE.md §2.4

# ── 클라이언트 (VITE_ 접두사, 번들에 노출됨) ──────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_LIVEKIT_URL=
VITE_SENTRY_DSN=
VITE_ENV=development

# ── Edge Function 전용 (비공개, 클라이언트 번들에 절대 노출 금지) ──
SUPABASE_SERVICE_ROLE_KEY=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SERVER_URL=
FAL_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
