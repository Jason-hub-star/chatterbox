{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/family/jason/ChatterBox/.codex/hooks/self-review-gate.sh'",
            "timeout": 5000,
            "statusMessage": "Self-review gate..."
          },
          {
            "type": "command",
            "command": "'/Users/family/jason/ChatterBox/.codex/hooks/doc-drift-reminder.sh'",
            "timeout": 5000,
            "statusMessage": "Doc drift reminder..."
          },
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '(GAP-MATRIX|contracts/_INDEX|FEATURE-SPEC|DATA-SCHEMA|state-machines)' && node scripts/gen-overview.cjs 2>/dev/null || true",
            "timeout": 10000,
            "statusMessage": "Overview sync..."
          }
        ]
      }
    ]
  }
}
